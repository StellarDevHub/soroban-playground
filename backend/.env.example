# Backend environment variables for soroban-playground
# Copy this to .env and customize per environment

# App
PORT=5000
APP_ENV=development

# CORS
# Leave blank to keep the current permissive behavior.
# Use comma-separated origins to restrict browser access in deployed environments.
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_ALLOWED_HEADERS=
CORS_EXPOSED_HEADERS=
CORS_MAX_AGE_SECONDS=86400

# Rate limiting (milliseconds and counts)
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=1000
COMPILE_RATE_LIMIT_WINDOW_MS=60000
COMPILE_RATE_LIMIT_MAX=10

# Compile settings
COMPILE_COMMAND=cargo build --target wasm32-unknown-unknown --release
COMPILE_TIMEOUT_MS=30000
COMPILE_TEMP_DIR_PREFIX=.tmp_compile_
WASM_TARGET_SUBPATH=target/wasm32-unknown-unknown/release
WASM_FILENAME=soroban_contract.wasm
SOROBAN_SDK_VERSION=20.0.0

# Network defaults
DEFAULT_NETWORK=testnet

# Simulation delays for stubbed routes (milliseconds)
DEPLOY_SIMULATED_DELAY_MS=1500
INVOKE_SIMULATED_DELAY_MS=1000

# Database Configuration
DB_TYPE=sqlite
DATABASE_URL=sqlite://indexer.db
SECONDARY_DATABASE_URL=postgresql://user:pass@localhost:5432/indexer

# File Notary Contract
NOTARY_CONTRACT_ID=your-contract-id-here
STELLAR_NETWORK=testnet

# Transaction Fee Escalation Engine (#745)
FEE_ENGINE_MAX_FEE=10000
FEE_ENGINE_ESCALATION_FACTOR=1.5
FEE_ENGINE_MAX_ATTEMPTS=5

# Automated secret rotation (issue #738) — all optional, off by default.
# AES key for the in-memory credential store (random per-process if unset).
CREDENTIAL_ENCRYPTION_KEY=
# Optional JSON file holding rotatable credentials (e.g. { "REDIS_URL": "..." }).
CREDENTIAL_SOURCE_FILE=
# Periodic source-file poll interval in ms; 0 disables the periodic check.
CREDENTIAL_ROTATION_INTERVAL_MS=0
# Grace period (ms) before the old DB handle is closed after a rotation.
CREDENTIAL_ROTATION_GRACE_MS=5000
# Shared secret for the POST /api/credentials/rotate webhook; unset disables it.
CREDENTIAL_ROTATION_WEBHOOK_SECRET=

# ─── Automated SQLite Backups ─────────────────────────────────────────────────
# Set BACKUP_ENABLED=true to activate the scheduled backup cron job.
BACKUP_ENABLED=false

# Cron expression for the backup schedule (default: daily at 02:00).
BACKUP_CRON_SCHEDULE=0 2 * * *

# AWS S3 destination bucket (required when BACKUP_ENABLED=true).
BACKUP_S3_BUCKET=

# S3 object key prefix — all backup objects are stored under this path.
BACKUP_S3_PREFIX=sqlite-backups/

# AWS region of the S3 bucket.
BACKUP_S3_REGION=us-east-1

# AES-256 encryption key as a 64-character hex string (32 bytes, required).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=

# Number of daily backups to retain in S3 before pruning older ones (default: 30).
BACKUP_RETENTION_COUNT=30

# Temporary directory for SQLite snapshots during the backup pipeline.
# Defaults to the OS temp dir. Must have sufficient free space for one DB copy.
BACKUP_TEMP_DIR=
